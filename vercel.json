{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "nodeVersion": "18.x",
  "functions": {
    "api/**/*.ts": {
      "runtime": "nodejs18.x"
    }
  },
  "routes": [
    {
      "src": "/api/data",
      "dest": "/api/data.ts",
      "methods": ["GET"]
    },
    {
      "src": "/api/login",
      "dest": "/api/login.ts",
      "methods": ["POST"]
    },
    {
      "src": "/api/signup",
      "dest": "/api/signup.ts",
      "methods": ["POST"]
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
